# Caddy reverse proxy: terminates TLS (automatic Let's Encrypt) and forwards to
# the gateway on the internal compose network. Used by docker-compose.prod.yml.
# Both hostnames are served (each gets its own auto-provisioned certificate);
# point each domain's A record at this host's public IP before starting.
ragassets.duckdns.org, assets.latam-tools.com.br {
	reverse_proxy gateway:8080
}

# URL shortener (sibling project `short`): runs as a bare systemd service on the
# host, not in compose — reached via the host-gateway alias (see extra_hosts on
# the caddy service in docker-compose.prod.yml).
short.latam-tools.com.br {
	reverse_proxy host.docker.internal:8081
}
