# Copy to .env and adjust as needed: `cp .env.example .env`

# Host port the public gateway is published on (container always listens on 8080).
GATEWAY_PORT=8080

# Optional: pin the zrenderer access token instead of reading it from the shared
# secrets volume. Handy if you create the token yourself or run the services
# separately. Get the auto-generated one with: docker compose logs zrenderer
# ZRENDERER_TOKEN=
